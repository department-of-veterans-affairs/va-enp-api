						{
							"name": "create notification",
							"event": [
								{
									"listen": "prerequest",
									"script": {
										"exec": [
											"const crypto = require('crypto-js');",
											"",
											"const ADMIN_SECRET_KEY = pm.environment.get('enp-admin-secret') || '';",
											"const ALGORITHM = 'HS256';",
											"const ACCESS_TOKEN_EXPIRE_SECONDS = 15;",
											"",
											"function base64url(source) {",
											"    // Encode in classical base64",
											"    let encodedSource = crypto.enc.Base64.stringify(source);",
											"",
											"    // Remove padding equal characters",
											"    encodedSource = encodedSource.replace(/=+$/, '');",
											"",
											"    // Replace characters according to base64url specifications",
											"    encodedSource = encodedSource.replace(/\\+/g, '-');",
											"    encodedSource = encodedSource.replace(/\\//g, '_');",
											"",
											"    return encodedSource;",
											"}",
											"",
											"function generateToken(sigKey = ADMIN_SECRET_KEY) {",
											"    const header = {",
											"        typ: 'JWT',",
											"        alg: ALGORITHM,",
											"    };",
											"",
											"    var payload = {",
											"        iss: 'enp',",
											"        iat: Math.floor(Date.now() / 1000),",
											"        exp: Math.floor(Date.now() / 1000) + ACCESS_TOKEN_EXPIRE_SECONDS,",
											"    };",
											"",
											"    const stringifiedHeader = crypto.enc.Utf8.parse(JSON.stringify(header));",
											"    const encodedHeader = base64url(stringifiedHeader);",
											"",
											"    const stringifiedPayload = crypto.enc.Utf8.parse(JSON.stringify(payload));",
											"    const encodedPayload = base64url(stringifiedPayload);",
											"",
											"    const token = encodedHeader + \".\" + encodedPayload;",
											"",
											"    const signature = crypto.HmacSHA256(token, sigKey);",
											"    const encodedSignature = base64url(signature);",
											"",
											"    return token + \".\" + encodedSignature;",
											"}",
											"",
											"const token = generateToken();",
											"console.log(token);",
											"pm.environment.set('jwt_signed', token);"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
